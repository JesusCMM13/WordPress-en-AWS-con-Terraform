# project_name       = "wordpress"
# instance_type      = "t3.small"
# root_volume_size   = 20
# ssh_public_key_path = "~/.ssh/id_rsa.pub"
# ssh_allowed_cidr   = "1.2.3.4/32"  # ← Pon tu IP pública aquí

