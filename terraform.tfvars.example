# terraform.tfvars.example
# Copia este fichero a terraform.tfvars y rellena los valores
# NUNCA subas terraform.tfvars a Git (ya está en .gitignore)
###############################################################

# ─── Obligatorio ─────────────────────────────────────────────
db_password = "CambiaEstaContraseña!2024"   # ← Cambia esto

# ─── Opcionales (sobreescriben los defaults de variables.tf) ─
